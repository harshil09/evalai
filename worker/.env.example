# Copy real values from frontend/.env.local or Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
POLL_INTERVAL_SECONDS=3
MAX_CONCURRENT_JOBS=2
RESERVED_OUTPUT_TOKENS=4096
MODEL_CATALOG_CACHE_SECONDS=900
DEFAULT_REFERENCE_MODEL=gpt-4o

# Optional hybrid LLM coaching via OpenRouter (defaults OFF — rules/similarity only)
# OPENROUTER_API_KEY=your-openrouter-api-key-here
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=https://your-app.example.com
# OPENROUTER_APP_TITLE=EvalAI
# ENABLE_LLM_COACH=true
# LLM_COACH_MODEL=openai/gpt-4o-mini
# EMBEDDING_MODEL=openai/text-embedding-3-small
